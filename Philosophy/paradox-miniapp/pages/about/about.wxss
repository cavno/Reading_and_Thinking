.wrap { padding: 46rpx 40rpx 70rpx; }
.t-en { font-size: 20rpx; letter-spacing: 8rpx; color: var(--gold-deep); text-align: center; }
.t-cn { font-size: 46rpx; font-weight: 700; text-align: center; margin-top: 14rpx; letter-spacing: 2rpx; line-height: 1.5; }
.t-sub { font-size: 26rpx; color: var(--ink-mute); font-style: italic; text-align: center; margin: 18rpx 10rpx 44rpx; line-height: 1.8; }
.card { background: var(--paper-warm); border: 1rpx solid var(--line-soft); border-radius: 10rpx; padding: 30rpx 32rpx; margin-bottom: 24rpx; }
.c-h { font-size: 24rpx; letter-spacing: 4rpx; color: var(--gold-deep); margin-bottom: 16rpx; font-weight: 600; }
.c-p { font-size: 28rpx; color: var(--ink-soft); line-height: 1.95; margin-bottom: 14rpx; text-align: justify; }
.c-p:last-child { margin-bottom: 0; }
.em { color: var(--terra); font-weight: 600; }
.stats { display: flex; justify-content: space-around; background: var(--paper-deep); border-radius: 10rpx; padding: 30rpx 0; margin: 34rpx 0; }
.s-i { display: flex; flex-direction: column; align-items: center; }
.s-n { font-size: 44rpx; font-weight: 700; }
.s-l { font-size: 18rpx; letter-spacing: 4rpx; color: var(--ink-mute); margin-top: 6rpx; }
.coda { text-align: center; font-size: 24rpx; color: var(--ink-mute); font-style: italic; line-height: 1.9; padding: 10rpx 20rpx; }

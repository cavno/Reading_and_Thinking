.wrap { padding: 36rpx 36rpx 60rpx; }
.head { margin-bottom: 34rpx; }
.head-name { font-size: 52rpx; font-weight: 700; letter-spacing: 4rpx; }
.head-bar { width: 84rpx; height: 6rpx; border-radius: 3rpx; margin: 16rpx 0 12rpx; }
.head-count { font-size: 24rpx; color: var(--ink-mute); }
.era { font-size: 23rpx; color: var(--gold-deep); font-style: italic; letter-spacing: 3rpx; margin: 30rpx 4rpx 14rpx; padding-bottom: 8rpx; border-bottom: 1rpx dashed var(--line); }
.sys-row { background: var(--paper-warm); border: 1rpx solid var(--line-soft); border-radius: 8rpx; padding: 24rpx 26rpx 20rpx; margin-bottom: 18rpx; }
.sr-name { font-size: 32rpx; font-weight: 700; line-height: 1.5; }
.sr-mp { font-size: 25rpx; margin-top: 10rpx; line-height: 1.7; }
.pa { color: var(--aegean); }
.pb { color: var(--terra); }
.vs { color: var(--gold); }
.sr-meta { font-size: 22rpx; color: var(--ink-mute); margin-top: 12rpx; display: flex; justify-content: space-between; }
.sr-go { color: var(--terra); }

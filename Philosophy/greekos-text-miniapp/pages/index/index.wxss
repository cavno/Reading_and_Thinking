page{ background:#f3ebda;
  background-image:radial-gradient(ellipse at top,rgba(184,137,58,.05),transparent 60%);
  color:#1c1916; font-family:"Songti SC",Georgia,serif; }
.page,.reader{ min-height:100vh; padding-bottom:60rpx; }

/* ====== 目录：hero ====== */
.hero{ padding:46rpx 36rpx 22rpx; text-align:center; }
.eyebrow{ display:block; font-size:21rpx; letter-spacing:6rpx; color:#a73e2c; }
.htitle{ display:block; font-size:54rpx; font-weight:700; line-height:1.25; margin-top:18rpx; letter-spacing:1rpx; }
.hsub{ display:block; font-size:30rpx; color:#a73e2c; font-style:italic; margin-top:8rpx; letter-spacing:2rpx; }
.intro{ margin-top:24rpx; text-align:left; }
.ip{ display:block; font-size:25rpx; line-height:1.85; color:#3a342c; margin-bottom:12rpx; text-indent:2em; }

/* tabs */
.tabs{ display:flex; gap:0; margin:8rpx 36rpx 18rpx; border:1rpx solid rgba(28,25,22,.26); border-radius:32rpx; overflow:hidden; }
.tab{ flex:1; text-align:center; font-size:25rpx; color:#6e6253; padding:14rpx 0; }
.tab.on{ background:#1c1916; color:#faf4e6; font-weight:600; }

/* 总表网格 */
.grid{ display:flex; flex-wrap:wrap; justify-content:space-between; padding:0 30rpx; }
.gcell{ width:48.6%; box-sizing:border-box; background:#faf4e6; border:1rpx solid rgba(28,25,22,.18);
  border-radius:14rpx; padding:18rpx 18rpx; margin-bottom:14rpx; display:flex; flex-direction:column; }
.g-no{ font-size:19rpx; letter-spacing:2rpx; color:#a73e2c; font-family:"Courier New",monospace; }
.g-cn{ font-size:30rpx; font-weight:700; color:#1c1916; margin-top:7rpx; }
.g-gk{ font-size:21rpx; color:#6e6253; font-style:italic; margin-top:6rpx; }

/* 历史脉络 */
.flow{ padding:0 30rpx; }
.sec{ margin-bottom:22rpx; }
.sec-h{ display:flex; align-items:baseline; gap:14rpx; padding:14rpx 6rpx 12rpx; border-bottom:2rpx solid rgba(167,62,44,.5); }
.sec-roman{ font-size:40rpx; font-weight:700; color:#a73e2c; font-family:Georgia,serif; line-height:1; }
.sec-title{ font-size:28rpx; font-weight:700; color:#1c1916; }
.opp-row{ display:flex; align-items:center; gap:14rpx; padding:16rpx 6rpx; border-bottom:1rpx solid rgba(28,25,22,.1); }
.or-no{ flex:none; width:46rpx; height:46rpx; line-height:46rpx; text-align:center; font-size:22rpx;
  color:#a73e2c; border:1rpx solid #d9a89c; border-radius:50%; font-family:"Courier New",monospace; }
.or-tx{ flex:1; min-width:0; display:flex; flex-direction:column; }
.or-cn{ font-size:28rpx; font-weight:600; color:#1c1916; }
.or-gk{ font-size:20rpx; color:#6e6253; font-style:italic; margin-top:2rpx; }
.or-arrow{ flex:none; color:#b9ab95; font-size:30rpx; }
.syn-row{ display:flex; align-items:baseline; gap:14rpx; padding:18rpx 6rpx; margin-top:6rpx;
  background:#efe6d2; border-radius:12rpx; padding-left:16rpx; }
.syn-roman{ font-size:34rpx; font-weight:700; color:#a73e2c; font-family:Georgia,serif; }
.syn-title{ font-size:26rpx; font-weight:700; color:#1c1916; }

.foot,.rfoot{ text-align:center; font-size:20rpx; letter-spacing:2rpx; color:#9a8e7c; padding:28rpx 30rpx 10rpx; }

/* ====== 阅读视图 ====== */
.rbar{ position:sticky; top:0; z-index:10; display:flex; align-items:center; gap:12rpx;
  background:rgba(243,235,218,.94); backdrop-filter:blur(8rpx);
  padding:16rpx 26rpx; border-bottom:1rpx solid rgba(28,25,22,.12); }
.rb-back{ flex:none; font-size:24rpx; color:#a73e2c; border:1rpx solid #d9a89c; border-radius:26rpx; padding:6rpx 16rpx; }
.rb-crumb{ flex:1; min-width:0; font-size:22rpx; color:#6e6253; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
.rb-pos{ flex:none; font-size:21rpx; color:#a73e2c; font-family:"Courier New",monospace; letter-spacing:1rpx; }

/* 阶段导言 hero */
.sect-hero,.syn-hero{ padding:50rpx 36rpx 12rpx; }
.sect-roman{ display:block; font-size:96rpx; font-weight:700; color:rgba(167,62,44,.85); font-family:Georgia,serif; line-height:1; }
.sect-h1{ display:block; font-size:42rpx; font-weight:700; line-height:1.3; margin-top:12rpx; }

/* 对立 hero */
.opp-hero{ padding:46rpx 36rpx 14rpx; border-bottom:1rpx solid rgba(28,25,22,.12); margin:0 0 6rpx; }
.oh-no{ display:block; font-size:22rpx; letter-spacing:3rpx; color:#a73e2c; font-family:"Courier New",monospace; }
.oh-gk{ display:block; font-size:46rpx; font-weight:600; font-style:italic; line-height:1.22; margin-top:10rpx; color:#1c1916; }
.oh-cn{ display:block; font-size:30rpx; color:#6e6253; margin-top:8rpx; letter-spacing:2rpx; }

/* 正文排版 */
.body{ padding:20rpx 36rpx 10rpx; }
.bp{ display:block; font-size:31rpx; line-height:1.92; color:#26221c; margin-bottom:20rpx; text-indent:2em; }
.bp.muted{ color:#9a8e7c; font-style:italic; text-indent:0; }
.li{ display:flex; gap:12rpx; margin-bottom:14rpx; padding-left:12rpx; }
.li-dot{ flex:none; color:#a73e2c; font-weight:700; line-height:1.9; }
.li-tx{ flex:1; font-size:29rpx; line-height:1.85; color:#3a342c; }

/* 翻页 */
.pager{ display:flex; align-items:center; gap:12rpx; padding:24rpx 30rpx 8rpx; }
.pg{ flex:1; text-align:center; font-size:25rpx; color:#3a342c; background:#faf4e6;
  border:1rpx solid rgba(28,25,22,.24); border-radius:30rpx; padding:14rpx 0; }
.pg.disabled{ opacity:.32; }
.pg2{ flex:none; font-size:24rpx; color:#a73e2c; padding:14rpx 24rpx; border:1rpx solid #d9a89c; border-radius:30rpx; }

.totop{ position:fixed; right:30rpx; bottom:120rpx; width:74rpx; height:74rpx; border-radius:50%;
  background:rgba(28,25,22,.82); color:#faf4e6; font-size:40rpx; line-height:74rpx; text-align:center;
  opacity:0; transform:translateY(20rpx); transition:all .25s; pointer-events:none; z-index:20; }
.totop.show{ opacity:1; transform:translateY(0); pointer-events:auto; }

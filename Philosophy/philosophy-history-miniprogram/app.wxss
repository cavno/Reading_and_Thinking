page {
  background: #f3eee3;
  color: #25231f;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.72;
}

view,
text,
scroll-view,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  font-size: inherit;
  line-height: inherit;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.page-pad {
  padding-left: 32rpx;
  padding-right: 32rpx;
}

.eyebrow {
  color: #a64f32;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 5rpx;
}

.display-title {
  margin-top: 16rpx;
  color: #17362f;
  font-family: "STSong", "Songti SC", serif;
  font-size: 62rpx;
  font-weight: 700;
  line-height: 1.18;
  letter-spacing: 2rpx;
}

.section-heading {
  color: #17362f;
  font-family: "STSong", "Songti SC", serif;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.muted {
  color: #777066;
}

.paper-card {
  border: 1rpx solid rgba(23, 54, 47, 0.11);
  border-radius: 24rpx;
  background: #fbf8f1;
  box-shadow: 0 14rpx 36rpx rgba(42, 35, 26, 0.06);
}

.rule {
  width: 72rpx;
  height: 5rpx;
  margin: 18rpx 0 24rpx;
  border-radius: 999rpx;
  background: #a64f32;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(23, 54, 47, 0.08);
  color: #355149;
  font-size: 23rpx;
  line-height: 1.35;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 20rpx 30rpx;
  border-radius: 18rpx;
  background: #17362f;
  color: #fffaf0;
  font-weight: 700;
}

.text-button {
  color: #a64f32;
  font-size: 26rpx;
  font-weight: 700;
}

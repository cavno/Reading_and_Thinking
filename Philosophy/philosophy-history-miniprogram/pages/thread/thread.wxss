.thread-hero {
  padding-top: 78rpx;
  padding-bottom: 50rpx;
}

.thread-hero .display-title {
  font-size: 60rpx;
}

.hero-copy {
  color: #625c53;
  font-size: 27rpx;
  line-height: 1.9;
}

.formula-wrap {
  padding-bottom: 34rpx;
}

.formula-card {
  padding: 28rpx 0 28rpx 28rpx;
  border-radius: 22rpx;
  background: #17362f;
  color: #fff9ec;
}

.formula-label {
  color: #d9ae75;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.formula-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.formula-row {
  display: inline-flex;
  align-items: center;
  padding-right: 28rpx;
  font-family: "STSong", "Songti SC", serif;
  font-size: 29rpx;
  font-weight: 700;
}

.formula-arrow {
  padding: 0 14rpx;
  color: #d9ae75;
}

.stage-tabs {
  position: sticky;
  z-index: 5;
  top: 0;
  background: rgba(243, 238, 227, 0.96);
  white-space: nowrap;
}

.stage-tab-row {
  display: inline-flex;
  padding: 18rpx 32rpx 20rpx;
}

.stage-tab {
  display: inline-flex;
  align-items: center;
  min-width: 120rpx;
  margin-right: 14rpx;
  padding: 14rpx 22rpx;
  border: 1rpx solid rgba(23, 54, 47, 0.14);
  border-radius: 999rpx;
  color: #6c655b;
  font-size: 24rpx;
}

.stage-tab-active {
  border-color: #17362f;
  background: #17362f;
  color: #fff9ec;
}

.tab-no {
  margin-right: 10rpx;
  color: #a64f32;
  font-family: "Times New Roman", serif;
  font-weight: 700;
}

.stage-tab-active .tab-no {
  color: #d9ae75;
}

.stage-scroll {
  height: 1120rpx;
}

.stage-list {
  padding-top: 34rpx;
  padding-bottom: 20rpx;
}

.stage-item {
  display: flex;
  align-items: stretch;
}

.stage-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 74rpx;
  flex: none;
}

.stage-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #a64f32;
  color: #fff;
  font-family: "Times New Roman", serif;
  font-size: 25rpx;
}

.stage-line {
  width: 2rpx;
  flex: 1;
  min-height: 70rpx;
  background: rgba(23, 54, 47, 0.16);
}

.stage-card {
  flex: 1;
  margin-bottom: 28rpx;
  padding: 32rpx;
}

.stage-age {
  color: #a64f32;
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.stage-title {
  margin-top: 10rpx;
  color: #17362f;
  font-family: "STSong", "Songti SC", serif;
  font-size: 38rpx;
  font-weight: 700;
}

.stage-formula {
  margin-top: 12rpx;
  color: #777066;
  font-size: 24rpx;
}

.stage-block {
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(23, 54, 47, 0.08);
}

.stage-block-label,
.tension-label {
  color: #8b8276;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.stage-block-text {
  margin-top: 8rpx;
  color: #36322d;
  font-size: 26rpx;
  line-height: 1.75;
}

.tension {
  margin-top: 22rpx;
  padding: 22rpx;
  border-left: 6rpx solid #d9ae75;
  background: #f4ecdf;
  color: #5f594f;
  font-size: 25rpx;
}

.tension-label {
  margin-bottom: 8rpx;
  color: #a64f32;
}

.stage-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 26rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(23, 54, 47, 0.08);
  color: #17362f;
  font-size: 24rpx;
  font-weight: 700;
}

.sediment {
  padding-top: 58rpx;
}

.sediment-card {
  padding: 42rpx 36rpx;
  border-radius: 24rpx;
  background: #a64f32;
  color: #fff7ec;
}

.sediment-card .eyebrow {
  color: #f1c99d;
}

.sediment-title {
  margin-top: 14rpx;
  font-family: "STSong", "Songti SC", serif;
  font-size: 40rpx;
  font-weight: 700;
}

.sediment-copy {
  margin-top: 20rpx;
  color: rgba(255, 247, 236, 0.82);
  font-size: 26rpx;
  line-height: 1.9;
}

.cross-section {
  padding-top: 72rpx;
  padding-bottom: 30rpx;
}

.cross-section .section-heading {
  margin-top: 8rpx;
  margin-bottom: 30rpx;
}

.cross-card {
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.cross-top {
  display: flex;
  align-items: center;
}

.cross-index {
  margin-right: 18rpx;
  color: #a64f32;
  font-family: "Times New Roman", serif;
  font-size: 34rpx;
}

.cross-title {
  color: #17362f;
  font-family: "STSong", "Songti SC", serif;
  font-size: 32rpx;
  font-weight: 700;
}

.cross-path {
  margin-top: 18rpx;
  color: #a64f32;
  font-size: 23rpx;
  line-height: 1.75;
}

.cross-insight {
  margin-top: 16rpx;
  color: #625c53;
  font-size: 25rpx;
  line-height: 1.85;
}

.glossary-hero {
  padding-top: 76rpx;
  padding-bottom: 48rpx;
}

.glossary-hero .display-title {
  font-size: 57rpx;
}

.hero-copy {
  color: #625c53;
  font-size: 27rpx;
  line-height: 1.9;
}

.search-wrap {
  padding-bottom: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 94rpx;
  padding: 0 26rpx;
  border: 1rpx solid rgba(23, 54, 47, 0.12);
  border-radius: 20rpx;
  background: #fbf8f1;
}

.search-icon {
  margin-right: 16rpx;
  color: #a64f32;
  font-size: 38rpx;
}

.search-input {
  flex: 1;
  height: 94rpx;
  color: #2f2c27;
  font-size: 26rpx;
}

.search-placeholder {
  color: #9b9387;
}

.clear-button {
  color: #a64f32;
  font-size: 23rpx;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  padding: 6rpx 32rpx 20rpx;
}

.category {
  margin-right: 12rpx;
  padding: 13rpx 22rpx;
  border: 1rpx solid rgba(23, 54, 47, 0.13);
  border-radius: 999rpx;
  color: #6d665c;
  font-size: 23rpx;
}

.category-active {
  border-color: #17362f;
  background: #17362f;
  color: #fff9ec;
}

.result-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 14rpx;
  padding-bottom: 20rpx;
  color: #81796d;
  font-size: 22rpx;
}

.result-category {
  color: #a64f32;
  font-weight: 700;
}

.term-card {
  margin-bottom: 22rpx;
  padding: 32rpx;
}

.term-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.term-category {
  color: #a64f32;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.term-name {
  margin-top: 10rpx;
  color: #17362f;
  font-family: "STSong", "Songti SC", serif;
  font-size: 40rpx;
  font-weight: 700;
}

.term-original {
  margin-top: 4rpx;
  color: #81796d;
  font-family: "Times New Roman", serif;
  font-size: 25rpx;
  font-style: italic;
}

.term-index {
  color: rgba(23, 54, 47, 0.13);
  font-family: "Times New Roman", serif;
  font-size: 58rpx;
  font-weight: 700;
}

.term-brief {
  margin-top: 24rpx;
  color: #3d3933;
  font-size: 27rpx;
  line-height: 1.82;
}

.term-evolution {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f1eadf;
  color: #5e584f;
  font-size: 25rpx;
  line-height: 1.8;
}

.evolution-label {
  margin-bottom: 8rpx;
  color: #a64f32;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.term-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(23, 54, 47, 0.08);
}

.term-footer-label {
  color: #8a8277;
  font-size: 21rpx;
}

.lecture-links {
  display: flex;
  gap: 10rpx;
}

.lecture-chip {
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  background: rgba(23, 54, 47, 0.08);
  color: #17362f;
  font-size: 21rpx;
}

.empty {
  padding-top: 120rpx;
  text-align: center;
}

.empty-mark {
  color: rgba(23, 54, 47, 0.18);
  font-family: "Times New Roman", serif;
  font-size: 90rpx;
}

.empty-title {
  margin-top: 16rpx;
  color: #17362f;
  font-family: "STSong", "Songti SC", serif;
  font-size: 34rpx;
  font-weight: 700;
}

.empty-copy {
  margin-top: 12rpx;
  color: #81796d;
  font-size: 24rpx;
}

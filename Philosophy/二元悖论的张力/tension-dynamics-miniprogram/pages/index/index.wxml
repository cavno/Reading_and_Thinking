<view class="page-root {{rootClass}}">

  <!-- 自定义导航栏 -->
  <view class="nav {{navSolid ? 'nav-solid' : ''}}" style="padding-top:{{statusBarHeight}}px;">
    <view class="nav-inner" style="height:{{navBarHeight}}px;">
      <text class="nav-title nav-home-title {{navSolid ? 'show' : ''}}">在不可消解的张力中安居</text>
    </view>
  </view>

  <scroll-view scroll-y="true" class="scroll" style="padding-top:{{statusBarHeight + navBarHeight}}px;" enable-back-to-top="true">

    <!-- Hero -->
    <view class="hero">
      <view class="theme-toggle tap" bindtap="toggleTheme">
        <text class="tt-dot"></text>
        <text class="tt-label">{{rootClass ? '夜读' : '日间'}}</text>
      </view>

      <view class="hero-eyebrow">
        <view class="eb-line"></view>
        <text>二元悖论的张力 · 系统动力学</text>
        <view class="eb-line"></view>
      </view>

      <view class="hero-title serif">在不可消解的\n张力中安居</view>

      <view class="hero-sub">十二篇动力学分析 —— 以成对的矛盾，作为系统演化的引擎</view>

      <view class="hero-seal-row">
        <view class="seal hero-seal serif">未济</view>
        <view class="hero-seal-text">
          <text class="serif">亨</text>
          <text class="hssub">工作永远不会完成，但通过工作，通达</text>
        </view>
      </view>
    </view>

    <!-- 框架说明入口 -->
    <view class="intro tap" bindtap="openAbout">
      <view class="intro-quote serif">「</view>
      <view class="intro-text">每一篇都从一个无法消解的<text class="em">母悖论</text>出发，展开九重张力，以<text class="em">元结论</text>收束。张力不是缺陷，而是系统持续运动的动力。</view>
      <view class="intro-link">了解这套框架<text class="chev">›</text></view>
    </view>

    <!-- 分类与卡片 -->
    <block wx:for="{{groups}}" wx:for-item="g" wx:key="*this">
      <view class="section">
        <view class="sec-head">
          <view class="sec-head-left">
            <view class="sec-dot" style="background:{{g.cat.color}}"></view>
            <view>
              <view class="sec-name serif">{{g.cat.name}}</view>
              <view class="sec-en">{{g.cat.en}}</view>
            </view>
          </view>
          <view class="sec-count">{{g.items.length}} 篇</view>
        </view>
        <view class="sec-desc">{{g.cat.desc}}</view>

        <view class="cards">
          <view class="card tap" wx:for="{{g.items}}" wx:key="id" data-id="{{item.id}}" bindtap="openArticle">
            <view class="card-bar" style="background:{{g.cat.color}}"></view>
            <view class="card-body">
              <view class="card-top">
                <text class="card-no serif">{{item.no}}</text>
                <view class="card-divider"></view>
                <text class="card-sub">{{item.sub}}</text>
              </view>
              <view class="card-title serif">{{item.title}}</view>
              <view class="card-tension">
                <text class="ct-mark" style="color:{{g.cat.color}}">◇</text>
                <text class="ct-text">{{item.tension}}</text>
              </view>
            </view>
            <view class="card-go">›</view>
          </view>
        </view>
      </view>
    </block>

    <!-- 页脚 -->
    <view class="foot">
      <view class="foot-seal serif">未济，亨</view>
      <view class="foot-line">共十二篇 · 张力作为系统的动力</view>
    </view>

    <view style="height:40rpx;"></view>
  </scroll-view>
</view>

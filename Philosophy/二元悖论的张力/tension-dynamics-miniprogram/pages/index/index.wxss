.scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* 首页导航标题 */
.nav-home-title {
  text-align: center;
  font-family: "Songti SC", "STSong", serif;
}

/* ---------------- Hero ---------------- */
.hero {
  position: relative;
  padding: 56rpx 48rpx 40rpx;
}

.theme-toggle {
  position: absolute;
  top: 24rpx;
  right: 44rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 20rpx 8rpx 16rpx;
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  background: var(--card);
}
.tt-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--accent-2);
  box-shadow: inset -5rpx -5rpx 0 0 var(--card-2);
}
.tt-label {
  font-size: 22rpx;
  color: var(--ink-soft);
  letter-spacing: 1rpx;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 36rpx;
}
.hero-eyebrow text {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--ink-faint);
  white-space: nowrap;
}
.eb-line {
  flex: 1;
  height: 1rpx;
  background: var(--line);
}

.hero-title {
  margin-top: 36rpx;
  font-size: 78rpx;
  line-height: 1.28;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: var(--ink);
  white-space: pre-line;
}

.hero-sub {
  margin-top: 28rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: var(--ink-soft);
  letter-spacing: 1rpx;
}

.hero-seal-row {
  margin-top: 44rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}
.hero-seal {
  width: 92rpx;
  height: 92rpx;
  font-size: 34rpx;
  flex-direction: column;
  line-height: 1.1;
  border-radius: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(140,59,46,0.22);
}
.hero-seal-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.hero-seal-text .serif {
  font-size: 38rpx;
  color: var(--accent);
  letter-spacing: 6rpx;
}
.hssub {
  font-size: 23rpx;
  color: var(--ink-faint);
  letter-spacing: 1rpx;
}

/* ---------------- 框架入口 ---------------- */
.intro {
  position: relative;
  margin: 24rpx 40rpx 8rpx;
  padding: 40rpx 40rpx 34rpx;
  background: var(--card);
  border: 1rpx solid var(--line);
  border-radius: 22rpx;
  overflow: hidden;
}
.intro-quote {
  position: absolute;
  top: -28rpx;
  right: 16rpx;
  font-size: 160rpx;
  color: var(--line-soft);
  opacity: .7;
}
.intro-text {
  position: relative;
  font-size: 28rpx;
  line-height: 1.85;
  color: var(--ink-soft);
}
.intro-text .em {
  color: var(--accent);
  font-weight: 600;
}
.intro-link {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--accent-2);
  letter-spacing: 1rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.chev {
  font-size: 32rpx;
  line-height: 1;
}

/* ---------------- 分类区 ---------------- */
.section {
  margin-top: 56rpx;
  padding: 0 40rpx;
}
.sec-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sec-head-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}
.sec-dot {
  width: 16rpx;
  height: 40rpx;
  border-radius: 4rpx;
}
.sec-name {
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  color: var(--ink);
}
.sec-en {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: var(--ink-faint);
  margin-top: 2rpx;
}
.sec-count {
  font-size: 23rpx;
  color: var(--ink-faint);
  letter-spacing: 1rpx;
}
.sec-desc {
  margin: 16rpx 0 26rpx 34rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--ink-faint);
}

/* ---------------- 卡片 ---------------- */
.cards {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}
.card {
  position: relative;
  display: flex;
  align-items: stretch;
  background: var(--card);
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 18rpx var(--shadow);
}
.card-bar {
  width: 8rpx;
  flex-shrink: 0;
}
.card-body {
  flex: 1;
  padding: 30rpx 12rpx 30rpx 32rpx;
  min-width: 0;
}
.card-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.card-no {
  font-size: 30rpx;
  color: var(--ink-faint);
  letter-spacing: 1rpx;
  font-weight: 600;
}
.card-divider {
  width: 1rpx;
  height: 22rpx;
  background: var(--line);
}
.card-sub {
  font-size: 23rpx;
  color: var(--ink-faint);
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.card-title {
  margin-top: 14rpx;
  font-size: 38rpx;
  line-height: 1.42;
  font-weight: 600;
  color: var(--ink);
  letter-spacing: 1rpx;
}
.card-tension {
  margin-top: 18rpx;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}
.ct-mark {
  font-size: 22rpx;
  flex-shrink: 0;
}
.ct-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--ink-soft);
  letter-spacing: .5rpx;
}
.card-go {
  display: flex;
  align-items: center;
  padding: 0 26rpx 0 8rpx;
  font-size: 40rpx;
  color: var(--ink-faint);
  font-weight: 300;
}

/* ---------------- 页脚 ---------------- */
.foot {
  margin-top: 72rpx;
  padding: 48rpx 40rpx 20rpx;
  text-align: center;
  border-top: 1rpx solid var(--line-soft);
}
.foot-seal {
  font-size: 40rpx;
  letter-spacing: 12rpx;
  color: var(--accent);
  text-indent: 12rpx;
}
.foot-line {
  margin-top: 18rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--ink-faint);
}

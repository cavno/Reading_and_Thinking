<view class="page-root {{rootClass}}">

  <!-- 自定义沉浸导航 + 阅读进度 -->
  <view class="nav nav-solid art-nav" style="padding-top:{{statusBarHeight}}px;">
    <view class="nav-inner" style="height:{{navBarHeight}}px;">
      <view class="nav-back tap" bindtap="goBack"><view class="ic"></view></view>
      <text class="nav-title {{showTitle ? 'show' : ''}}" style="padding-right:{{capsuleRight}}px;">{{meta.title}}</text>
    </view>
    <view class="progress-track">
      <view class="progress-fill" style="width:{{progress * 100}}%; background:{{catColor}};"></view>
    </view>
  </view>

  <scroll-view
    scroll-y="true"
    class="reading {{fontClass}}"
    style="padding-top:{{statusBarHeight + navBarHeight}}px;"
    scroll-into-view="{{intoView}}"
    scroll-with-animation="true"
    bindscroll="onContentScroll"
    enable-back-to-top="false">

    <view id="reading-top"></view>

    <!-- 篇首 -->
    <view class="art-hero">
      <view class="art-tag" style="color:{{catColor}}; border-color:{{catColor}};">{{catName}} · {{meta.no}}</view>
      <view class="art-title serif">{{meta.title}}</view>
      <view class="art-sub">{{meta.sub}}</view>
      <view class="art-tension serif">{{meta.tension}}</view>
      <view class="art-rule"><view class="art-rule-dot" style="background:{{catColor}}"></view></view>
    </view>

    <!-- 正文 -->
    <view class="body">
      <block wx:for="{{blocks}}" wx:key="index" wx:for-item="b">

        <view wx:if="{{b.type === 'h2'}}" id="{{b.id}}" class="blk-h2 kind-{{b.kind}}">
          <view wx:if="{{b.kind==='core' || b.kind==='meta'}}" class="h2-badge serif" style="background:{{catColor}}">{{b.kind==='core' ? '母悖论' : '元结论'}}</view>
          <view class="h2-text serif">
            <text wx:for="{{b.segs}}" wx:key="i" wx:for-item="s" class="{{s.b ? 'bold' : ''}}">{{s.t}}</text>
          </view>
        </view>

        <view wx:elif="{{b.type === 'h3'}}" class="blk-h3 serif">
          <text wx:for="{{b.segs}}" wx:key="i" wx:for-item="s" class="{{s.b ? 'bold' : ''}}">{{s.t}}</text>
        </view>

        <view wx:elif="{{b.type === 'hr'}}" class="blk-hr"></view>

        <view wx:elif="{{b.type === 'li'}}" class="blk-li">
          <text class="li-dot" style="color:{{catColor}}">·</text>
          <text class="li-text">
            <text wx:for="{{b.segs}}" wx:key="i" wx:for-item="s" class="{{s.b ? 'bold' : ''}}">{{s.t}}</text>
          </text>
        </view>

        <view wx:else class="blk-p {{b.verse ? 'verse' : ''}}">
          <text wx:for="{{b.segs}}" wx:key="i" wx:for-item="s" class="{{s.b ? 'bold' : ''}}">{{s.t}}</text>
        </view>

      </block>
    </view>

    <view class="art-end">
      <view class="art-end-seal serif">未济，亨</view>
    </view>
    <view style="height:120rpx;"></view>
  </scroll-view>

  <!-- 浮动工具 -->
  <view class="fab-col">
    <view class="fab tap {{showTop ? 'fab-show' : 'fab-hide'}}" bindtap="backToTop">
      <view class="fab-up"></view>
    </view>
    <view class="fab tap" bindtap="cycleFont">
      <text class="fab-aa serif">A<text class="aa-small">a</text></text>
      <text class="fab-mini">{{fontLabel}}</text>
    </view>
    <view class="fab tap" bindtap="toggleTheme">
      <view class="fab-moon {{rootClass ? 'is-dark':''}}"></view>
    </view>
    <view class="fab fab-toc tap" style="background:{{catColor}}" bindtap="openToc">
      <view class="toc-bars"><view></view><view></view><view></view></view>
    </view>
  </view>

  <!-- 目录抽屉 -->
  <view wx:if="{{tocOpen}}" class="sheet-mask" bindtap="closeToc">
    <view class="sheet" catchtap="noop">
      <view class="sheet-grip"></view>
      <view class="sheet-head">
        <text class="sheet-title serif">目录</text>
        <text class="sheet-sub">{{meta.title}}</text>
      </view>
      <scroll-view scroll-y="true" class="sheet-list">
        <view class="toc-item tap" wx:for="{{outline}}" wx:key="id" data-sid="{{item.id}}" bindtap="jumpTo">
          <view class="toc-mark kind-{{item.kind}}" style="background:{{(item.kind==='core'||item.kind==='meta') ? catColor : 'transparent'}}; border-color:{{catColor}};"></view>
          <text class="toc-text {{(item.kind==='core'||item.kind==='meta') ? 'toc-strong' : ''}}">{{item.text}}</text>
        </view>
        <view style="height:40rpx;"></view>
      </scroll-view>
    </view>
  </view>

</view>

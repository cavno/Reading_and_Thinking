.page {
  width: 100%;
  height: 100vh;
  background: var(--paper);
}

/* ===== Hero ===== */
.hero {
  background: radial-gradient(circle at 50% 36%, #1f1a16 0%, #14110f 60%, #0d0b09 100%);
  padding: 90rpx 56rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-figure {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  margin-bottom: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ring {
  position: absolute;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.ring-outer {
  width: 360rpx;
  height: 360rpx;
  border: 1rpx dashed rgba(184, 135, 70, 0.4);
}
.ring-gold {
  width: 268rpx;
  height: 268rpx;
  border: 1rpx solid rgba(184, 135, 70, 0.55);
  box-shadow: 0 0 40rpx rgba(184, 135, 70, 0.15);
}
.void-core {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, #050403 0%, #100d0b 70%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 50rpx rgba(0, 0, 0, 0.9);
}
.light-center {
  position: absolute;
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.85) 0%, rgba(184, 135, 70, 0.12) 70%, transparent 100%);
  top: 36rpx;
}
.void-label {
  font-size: 40rpx;
  color: var(--gold-bright);
  letter-spacing: 8rpx;
  margin-top: 34rpx;
  text-indent: 8rpx;
}
.void-latin {
  font-size: 18rpx;
  font-style: italic;
  letter-spacing: 4rpx;
  color: rgba(184, 135, 70, 0.6);
  margin-top: 6rpx;
}

.hero-eyebrow {
  font-style: italic;
  letter-spacing: 4rpx;
  color: var(--gold);
  font-size: 24rpx;
  margin-bottom: 28rpx;
}
.hero-title {
  font-size: 76rpx;
  line-height: 1.25;
  color: #f4ede0;
  font-weight: 600;
  letter-spacing: 4rpx;
}
.hero-title .hl { color: var(--gold-bright); }
.hero-sub {
  font-style: italic;
  font-size: 26rpx;
  color: rgba(244, 237, 224, 0.5);
  letter-spacing: 2rpx;
  margin-top: 18rpx;
}
.hero-lede {
  font-size: 28rpx;
  line-height: 1.85;
  color: rgba(244, 237, 224, 0.78);
  margin-top: 40rpx;
  max-width: 600rpx;
}
.hero-lede .em { color: var(--gold-bright); }
.hero-meta {
  margin-top: 46rpx;
  font-size: 24rpx;
  color: rgba(244, 237, 224, 0.55);
  letter-spacing: 2rpx;
}
.hero-meta .dot { margin: 0 16rpx; color: var(--gold); }
.hero-hint {
  margin-top: 48rpx;
  font-size: 22rpx;
  font-style: italic;
  letter-spacing: 3rpx;
  color: rgba(184, 135, 70, 0.7);
}

/* ===== 核心命题 ===== */
.thesis {
  background: var(--paper-warm);
  border-bottom: 1rpx solid var(--line);
  padding: 72rpx 56rpx 64rpx;
  text-align: center;
}
.thesis-mark {
  font-size: 90rpx;
  color: var(--gold);
  line-height: 0.5;
  height: 60rpx;
}
.thesis-body {
  font-size: 38rpx;
  line-height: 1.7;
  color: var(--ink);
  font-weight: 500;
}
.thesis-hl {
  color: var(--crimson);
  border-bottom: 3rpx solid rgba(184, 135, 70, 0.5);
  padding-bottom: 2rpx;
}
.thesis-note {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--slate);
  margin-top: 32rpx;
  max-width: 600rpx;
  margin-left: auto;
  margin-right: auto;
}

/* ===== 目录头 ===== */
.toc-head {
  padding: 72rpx 56rpx 16rpx;
}
.toc-title {
  font-size: 56rpx;
  color: var(--ink);
  font-weight: 600;
  letter-spacing: 2rpx;
}
.toc-desc {
  font-size: 26rpx;
  color: var(--slate);
  margin-top: 18rpx;
  line-height: 1.7;
}

/* ===== 目录列表 ===== */
.toc-list {
  padding: 32rpx 40rpx 0;
}
.toc-item {
  display: flex;
  align-items: center;
  padding: 36rpx 28rpx;
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
  margin-bottom: 22rpx;
  position: relative;
  overflow: hidden;
}
.toc-item::before {
  content: "";
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 6rpx;
  background: var(--gold);
}
.toc-roman {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}
.roman-cn {
  font-size: 52rpx;
  color: var(--crimson);
  font-weight: 600;
  line-height: 1;
}
.roman-phase {
  font-size: 16rpx;
  font-style: italic;
  letter-spacing: 2rpx;
  color: var(--gold-deep);
  margin-top: 10rpx;
}
.toc-main {
  flex: 1;
  padding: 0 16rpx;
}
.toc-item-title {
  font-size: 34rpx;
  color: var(--ink);
  font-weight: 600;
  letter-spacing: 1rpx;
}
.toc-item-sub {
  font-size: 24rpx;
  color: var(--slate);
  margin-top: 8rpx;
}
.toc-arrow {
  font-size: 36rpx;
  color: var(--gold);
  flex-shrink: 0;
}

/* ===== 页脚 ===== */
.footer {
  margin-top: 40rpx;
  padding: 80rpx 56rpx 40rpx;
  background: radial-gradient(circle at 50% 0%, #1f1a16 0%, #14110f 100%);
  text-align: center;
}
.footer-line {
  width: 60rpx;
  height: 2rpx;
  background: var(--gold);
  margin: 0 auto 40rpx;
}
.footer-quote {
  font-size: 36rpx;
  color: var(--gold-bright);
  letter-spacing: 4rpx;
  margin-bottom: 28rpx;
}
.footer-cite {
  font-size: 28rpx;
  line-height: 1.8;
  color: rgba(244, 237, 224, 0.8);
  max-width: 580rpx;
  margin: 0 auto;
}
.footer-mark {
  font-size: 22rpx;
  font-style: italic;
  letter-spacing: 2rpx;
  color: rgba(244, 237, 224, 0.45);
  margin-top: 36rpx;
}
.bottom-safe {
  height: env(safe-area-inset-bottom);
  background: #14110f;
}

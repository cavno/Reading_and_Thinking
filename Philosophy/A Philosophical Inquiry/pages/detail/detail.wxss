.page {
  width: 100%;
  height: 100vh;
  background: var(--paper);
}

/* ===== 章节头 ===== */
.chap-head {
  background: radial-gradient(circle at 50% 0%, #1f1a16 0%, #14110f 100%);
  padding: 70rpx 56rpx 64rpx;
  text-align: center;
}
.chap-roman {
  font-size: 90rpx;
  color: var(--gold-bright);
  font-weight: 600;
  line-height: 1;
}
.chap-roman-latin {
  font-size: 22rpx;
  font-style: italic;
  letter-spacing: 6rpx;
  color: rgba(184, 135, 70, 0.6);
  margin-top: 14rpx;
}
.chap-title {
  font-size: 56rpx;
  color: #f4ede0;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-top: 30rpx;
  line-height: 1.3;
}
.chap-sub {
  font-size: 24rpx;
  font-style: italic;
  color: rgba(244, 237, 224, 0.5);
  letter-spacing: 1rpx;
  margin-top: 16rpx;
}
.chap-intro {
  font-size: 27rpx;
  line-height: 1.85;
  color: rgba(244, 237, 224, 0.8);
  margin-top: 36rpx;
  text-align: left;
}

/* ===== 正文容器 ===== */
.body {
  padding: 60rpx 48rpx 20rpx;
}
.body .section-label { margin-top: 56rpx; }
.body .section-label:first-child { margin-top: 0; }

/* ===== 引文块 ===== */
.quote-block {
  border-left: 6rpx solid var(--gold);
  padding: 8rpx 0 8rpx 32rpx;
  margin-bottom: 16rpx;
}
.quote-text {
  font-size: 30rpx;
  line-height: 1.9;
  color: var(--ink-soft);
  font-style: italic;
}

/* ===== 前言：四根基 ===== */
.pillar-list { margin-top: 28rpx; }
.pillar {
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
  padding: 32rpx 34rpx;
  margin-bottom: 20rpx;
}
.pillar-k {
  font-size: 36rpx;
  color: var(--crimson);
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}
.pillar-v {
  font-size: 27rpx;
  line-height: 1.8;
  color: var(--slate);
}

/* ===== 第一章：思想家 ===== */
.chip-bar {
  white-space: nowrap;
  margin-bottom: 40rpx;
}
.chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 30rpx;
  margin-right: 18rpx;
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
}
.chip-on {
  background: var(--ink);
  border-color: var(--ink);
}
.chip-year {
  font-size: 20rpx;
  font-style: italic;
  color: var(--gold-deep);
}
.chip-on .chip-year { color: var(--gold-bright); }
.chip-name {
  font-size: 28rpx;
  color: var(--ink);
  font-weight: 600;
  margin-top: 6rpx;
}
.chip-on .chip-name { color: #f4ede0; }

.thinker-card {
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-top: 4rpx solid var(--gold);
  border-radius: 8rpx;
  padding: 44rpx 38rpx;
}
.tk-tag {
  display: inline-block;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--gold-deep);
  border: 1rpx solid rgba(184, 135, 70, 0.4);
  border-radius: 4rpx;
  padding: 4rpx 16rpx;
}
.tk-name {
  font-size: 52rpx;
  color: var(--ink);
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-top: 22rpx;
}
.tk-latin {
  font-size: 24rpx;
  font-style: italic;
  color: var(--gold-deep);
  margin-top: 8rpx;
}
.tk-meta {
  font-size: 23rpx;
  color: var(--slate);
  margin-top: 6rpx;
}
.tk-headline {
  font-size: 34rpx;
  color: var(--crimson);
  font-weight: 600;
  line-height: 1.5;
  margin-top: 30rpx;
}
.tk-desc {
  font-size: 27rpx;
  line-height: 1.85;
  color: var(--ink-soft);
  margin-top: 20rpx;
}
.tk-quote {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--slate);
  font-style: italic;
  border-left: 4rpx solid var(--gold);
  padding-left: 24rpx;
  margin-top: 28rpx;
}

/* ===== 第二章：标签 ===== */
.tabs {
  display: flex;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 28rpx;
  color: var(--slate);
  background: #fbf6ec;
}
.tab-on {
  background: var(--ink);
  color: var(--gold-bright);
  font-weight: 600;
}

.type-card {
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
  padding: 34rpx 36rpx;
  margin-bottom: 20rpx;
}
.type-top {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}
.type-n {
  font-size: 56rpx;
  color: rgba(184, 135, 70, 0.5);
  font-weight: 600;
  font-style: italic;
  margin-right: 24rpx;
  line-height: 1;
}
.type-name {
  font-size: 34rpx;
  color: var(--ink);
  font-weight: 600;
}
.type-latin {
  font-size: 22rpx;
  font-style: italic;
  color: var(--gold-deep);
  margin-top: 4rpx;
}
.type-desc {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--slate);
}

.manifest {
  display: flex;
  padding: 28rpx 8rpx;
  border-bottom: 1rpx solid var(--line);
}
.manifest-n {
  width: 60rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  font-style: italic;
  color: var(--gold);
  font-weight: 600;
}
.manifest-title {
  font-size: 30rpx;
  color: var(--ink);
  font-weight: 600;
}
.manifest-desc {
  font-size: 25rpx;
  line-height: 1.75;
  color: var(--slate);
  margin-top: 8rpx;
}

/* ===== 第三章：根源 ===== */
.root-card {
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
  padding: 34rpx 36rpx;
  margin-bottom: 20rpx;
}
.root-icon {
  font-size: 30rpx;
  font-style: italic;
  color: #fff;
  background: var(--gold-deep);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 56rpx;
  margin-bottom: 18rpx;
}
.root-title {
  font-size: 34rpx;
  color: var(--crimson);
  font-weight: 600;
  margin-bottom: 16rpx;
}
.root-item {
  font-size: 26rpx;
  line-height: 1.9;
  color: var(--slate);
}

.cage {
  background: var(--ink);
  border-radius: 8rpx;
  padding: 48rpx 40rpx;
  margin-top: 36rpx;
  position: relative;
  overflow: hidden;
}
.cage-bars {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image: repeating-linear-gradient(
    90deg,
    rgba(184, 135, 70, 0.16) 0,
    rgba(184, 135, 70, 0.16) 2rpx,
    transparent 2rpx,
    transparent 44rpx
  );
}
.cage-title {
  font-size: 36rpx;
  color: var(--gold-bright);
  font-weight: 600;
  position: relative;
}
.cage-latin {
  font-size: 22rpx;
  font-style: italic;
  color: rgba(184, 135, 70, 0.6);
  letter-spacing: 2rpx;
  margin-top: 10rpx;
  position: relative;
}
.cage-body {
  font-size: 27rpx;
  line-height: 1.85;
  color: rgba(244, 237, 224, 0.82);
  margin-top: 24rpx;
  position: relative;
}

/* ===== 第四章：机制 / 数据 ===== */
.mech-flow {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 28rpx;
}
.mech-step {
  width: 100%;
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-left: 5rpx solid var(--crimson);
  border-radius: 8rpx;
  padding: 26rpx 32rpx;
}
.mech-n {
  font-size: 20rpx;
  font-style: italic;
  letter-spacing: 2rpx;
  color: var(--gold-deep);
}
.mech-t {
  font-size: 32rpx;
  color: var(--ink);
  font-weight: 600;
  margin-top: 6rpx;
}
.mech-arrow {
  font-size: 32rpx;
  color: var(--gold);
  padding: 12rpx 0;
}

.cycle {
  background: rgba(107, 43, 43, 0.08);
  border: 1rpx solid rgba(107, 43, 43, 0.3);
  border-radius: 8rpx;
  padding: 32rpx 36rpx;
  margin-top: 40rpx;
  text-align: center;
}
.cycle-label {
  font-size: 22rpx;
  font-style: italic;
  letter-spacing: 2rpx;
  color: var(--crimson);
  margin-bottom: 14rpx;
}
.cycle-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ink-soft);
  font-weight: 500;
}

.stat-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 28rpx;
}
.stat {
  width: 100%;
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
  padding: 30rpx 34rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: baseline;
}
.stat-num {
  font-size: 64rpx;
  color: var(--gold-deep);
  font-weight: 600;
  line-height: 1;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.stat-unit {
  font-size: 32rpx;
}
.stat-label {
  font-size: 25rpx;
  line-height: 1.6;
  color: var(--slate);
}

.note-block {
  background: var(--ink);
  border-radius: 8rpx;
  padding: 40rpx 38rpx;
  margin-top: 40rpx;
  font-size: 27rpx;
  line-height: 1.85;
  color: rgba(244, 237, 224, 0.85);
}

/* ===== 第五章：出路 ===== */
.path-card {
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
  padding: 38rpx 38rpx;
  margin-bottom: 22rpx;
}
.path-root {
  background: radial-gradient(circle at 50% 0%, #1f1a16 0%, #14110f 100%);
  border-color: var(--gold);
}
.path-top {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
}
.path-roman {
  font-size: 56rpx;
  color: var(--gold);
  font-weight: 600;
  font-style: italic;
  margin-right: 24rpx;
  line-height: 1;
}
.path-title {
  font-size: 38rpx;
  color: var(--ink);
  font-weight: 600;
  display: flex;
  align-items: center;
}
.path-root .path-title { color: #f4ede0; }
.root-badge {
  font-size: 20rpx;
  color: #fff;
  background: var(--crimson);
  border-radius: 4rpx;
  padding: 4rpx 14rpx;
  margin-left: 18rpx;
  letter-spacing: 1rpx;
  font-weight: 400;
}
.path-latin {
  font-size: 22rpx;
  font-style: italic;
  color: var(--gold-deep);
  margin-top: 6rpx;
}
.path-root .path-latin { color: rgba(184, 135, 70, 0.7); }
.path-item {
  font-size: 26rpx;
  line-height: 1.95;
  color: var(--slate);
}
.path-root .path-item { color: rgba(244, 237, 224, 0.82); }

.evo-flow {
  margin-top: 28rpx;
}
.evo-step {
  background: #fbf6ec;
  border: 1rpx solid var(--line);
  border-radius: 8rpx;
  padding: 28rpx 34rpx;
}
.evo-stage {
  font-size: 20rpx;
  font-style: italic;
  letter-spacing: 3rpx;
  color: var(--gold-deep);
}
.evo-title {
  font-size: 36rpx;
  color: var(--crimson);
  font-weight: 600;
  margin-top: 6rpx;
}
.evo-desc {
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--slate);
  margin-top: 8rpx;
}
.evo-arrow {
  text-align: center;
  font-size: 30rpx;
  color: var(--gold);
  padding: 12rpx 0;
}

/* ===== 第六章：谱系 ===== */
.lineage { margin-top: 12rpx; }
.lin-step {
  display: flex;
  align-items: flex-start;
}
.lin-icon {
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: var(--ink);
  color: var(--gold-bright);
  font-size: 38rpx;
  text-align: center;
  line-height: 76rpx;
  font-style: italic;
}
.lin-main {
  flex: 1;
  padding: 4rpx 0 0 28rpx;
}
.lin-era {
  font-size: 20rpx;
  font-style: italic;
  letter-spacing: 3rpx;
  color: var(--gold-deep);
}
.lin-title {
  font-size: 36rpx;
  color: var(--ink);
  font-weight: 600;
  margin-top: 4rpx;
}
.lin-desc {
  font-size: 25rpx;
  line-height: 1.7;
  color: var(--slate);
  margin-top: 8rpx;
}
.lin-line {
  width: 2rpx;
  height: 44rpx;
  background: linear-gradient(var(--gold), transparent);
  margin: 8rpx 0 8rpx 37rpx;
}

.coda {
  background: radial-gradient(circle at 50% 0%, #1f1a16 0%, #14110f 100%);
  border-radius: 8rpx;
  padding: 60rpx 44rpx;
  margin-top: 48rpx;
  text-align: center;
}
.coda-mark {
  font-size: 48rpx;
  color: var(--gold);
  margin-bottom: 24rpx;
}
.coda-quote {
  font-size: 38rpx;
  line-height: 1.7;
  color: #f4ede0;
  font-weight: 500;
}
.coda-cite {
  font-size: 24rpx;
  font-style: italic;
  letter-spacing: 2rpx;
  color: var(--gold-bright);
  margin-top: 30rpx;
}
.coda-sub {
  font-size: 26rpx;
  color: rgba(244, 237, 224, 0.6);
  margin-top: 18rpx;
  letter-spacing: 3rpx;
}

/* ===== 章节间导航 ===== */
.chapter-nav {
  display: flex;
  align-items: stretch;
  border-top: 1rpx solid var(--line);
  margin-top: 40rpx;
  background: var(--paper-warm);
}
.nav-cell {
  flex: 1;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.nav-right { align-items: flex-end; text-align: right; }
.nav-toc {
  flex: 0 0 150rpx;
  align-items: center;
  border-left: 1rpx solid var(--line);
  border-right: 1rpx solid var(--line);
}
.nav-empty { flex: 1; }
.nav-dir {
  font-size: 22rpx;
  font-style: italic;
  color: var(--gold-deep);
}
.nav-name {
  font-size: 30rpx;
  color: var(--ink);
  font-weight: 600;
  margin-top: 6rpx;
}
.nav-toc-icon {
  font-size: 34rpx;
  color: var(--crimson);
}
.nav-toc .nav-name { margin-top: 4rpx; }

.bottom-safe {
  height: env(safe-area-inset-bottom);
  background: var(--paper-warm);
}

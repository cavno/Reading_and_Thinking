.thead { padding: 26rpx 8rpx 4rpx; }
.thead-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-top: 12rpx;
}
.thead-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 27rpx;
  color: #6f6452;
  line-height: 1.8;
}

.t-sec {
  display: block;
  text-align: center;
  font-size: 26rpx;
  letter-spacing: 8rpx;
  color: #5d5346;
  margin-bottom: 24rpx;
}

/* ---- 主轴 ---- */
.spine {
  background: #faf5ea;
  border: 1rpx solid rgba(28, 25, 22, 0.13);
  border-radius: 16rpx;
  padding: 30rpx 26rpx 10rpx;
}
.spine-row { display: flex; }
.spine-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 22rpx;
}
.spine-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
}
.sd-terra { background: #a73e2c; }
.sd-gold { background: #b8893a; }
.sd-aegean { background: #1d4e5f; }
.sd-wine { background: #7e2a38; }
.sd-ink { background: rgba(28, 25, 22, 0.4); }
.spine-line {
  width: 2rpx;
  flex: 1;
  background: rgba(28, 25, 22, 0.18);
  margin: 6rpx 0;
}
.spine-body { flex: 1; padding-bottom: 30rpx; }
.spine-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.spine-name { font-size: 33rpx; font-weight: 700; letter-spacing: 1rpx; }
.spine-lec { font-size: 21rpx; color: #a89878; letter-spacing: 2rpx; }
.spine-role {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  margin-top: 2rpx;
}
.sr-terra { color: #a73e2c; }
.sr-gold { color: #8a6420; }
.sr-aegean { color: #1d4e5f; }
.sr-wine { color: #7e2a38; }
.sr-ink { color: #5d5346; }
.spine-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #5d5346;
}

/* ---- 贯穿线 ---- */
.th-block {
  background: #faf5ea;
  border: 1rpx solid rgba(28, 25, 22, 0.13);
  border-radius: 16rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 28rpx;
}
.th-head { display: flex; align-items: flex-start; }
.th-no {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #1c1916;
  color: #b8893a;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  font-family: Georgia, serif;
}
.th-head-tx { flex: 1; }
.th-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  line-height: 1.5;
}
.th-sub {
  display: block;
  margin-top: 2rpx;
  font-size: 24rpx;
  color: #8a6420;
}
.th-intro {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.9;
  color: #463d30;
}
.th-stops { margin-top: 20rpx; }
.th-stop {
  display: flex;
  margin-bottom: 16rpx;
}
.th-stop-tag {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(28, 25, 22, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #5d5346;
  margin-right: 18rpx;
  margin-top: 4rpx;
}
.th-stop-tx {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.8;
  color: #463d30;
}
.th-close {
  margin-top: 8rpx;
  padding: 18rpx 22rpx;
  background: rgba(184, 137, 58, 0.12);
  border-left: 6rpx solid #b8893a;
  border-radius: 8rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #5d4a22;
}

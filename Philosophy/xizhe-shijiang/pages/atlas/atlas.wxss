/* ---- 标签 ---- */
.tabs {
  display: flex;
  background: #faf5ea;
  border: 1rpx solid rgba(28, 25, 22, 0.2);
  border-radius: 999rpx;
  padding: 6rpx;
  margin: 16rpx 0 28rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  color: #6f6452;
}
.tab-on {
  background: #1c1916;
  color: #f3ebda;
}

.a-intro {
  display: block;
  font-size: 26rpx;
  line-height: 1.85;
  color: #5d5346;
  margin-bottom: 26rpx;
  padding: 0 6rpx;
}

/* ---- 概念长河 ---- */
.cv-card {
  background: #faf5ea;
  border: 1rpx solid rgba(28, 25, 22, 0.13);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
}
.cv-head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  border-left: 10rpx solid #1c1916;
  padding-left: 18rpx;
}
.bd-terra { border-left-color: #a73e2c; }
.bd-gold { border-left-color: #b8893a; }
.bd-aegean { border-left-color: #1d4e5f; }
.bd-wine { border-left-color: #7e2a38; }
.bd-ink { border-left-color: #1c1916; }
.cv-name {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  font-family: Georgia, "Times New Roman", serif;
  margin-right: 16rpx;
}
.cv-cn { font-size: 27rpx; color: #6f6452; }
.cv-line {
  display: block;
  margin: 16rpx 0 20rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #8a6420;
}
.cv-stages {}
.cv-stage { display: flex; }
.cv-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}
.cv-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
}
.dt-terra { background: #a73e2c; }
.dt-gold { background: #b8893a; }
.dt-aegean { background: #1d4e5f; }
.dt-wine { background: #7e2a38; }
.dt-ink { background: #1c1916; }
.cv-rail-line {
  width: 2rpx;
  flex: 1;
  background: rgba(28, 25, 22, 0.18);
  margin: 4rpx 0;
}
.cv-body { flex: 1; padding-bottom: 24rpx; }
.cv-meta { display: flex; align-items: baseline; flex-wrap: wrap; }
.cv-era {
  font-size: 21rpx;
  letter-spacing: 2rpx;
  color: #f3ebda;
  background: #1c1916;
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
  margin-right: 14rpx;
}
.cv-who { font-size: 26rpx; font-weight: 700; }
.cv-tx {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #463d30;
}

/* ---- 张力 ---- */
.dg-block {
  background: #faf5ea;
  border: 1rpx solid rgba(28, 25, 22, 0.13);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
}
.dg-head { display: flex; align-items: center; }
.dg-bar {
  width: 14rpx;
  height: 36rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
}
.bg-terra { background: #a73e2c; }
.bg-gold { background: #b8893a; }
.bg-aegean { background: #1d4e5f; }
.bg-wine { background: #7e2a38; }
.bg-ink { background: #1c1916; }
.dg-title { font-size: 34rpx; font-weight: 700; letter-spacing: 1rpx; }
.dg-note {
  display: block;
  margin: 12rpx 0 20rpx;
  font-size: 23rpx;
  line-height: 1.75;
  color: #8a7a5e;
}
.dg-pair {
  padding: 18rpx 0;
  border-top: 1rpx dashed rgba(28, 25, 22, 0.15);
}
.dg-vs { display: flex; align-items: baseline; flex-wrap: wrap; }
.dg-a { font-size: 28rpx; font-weight: 700; color: #1d4e5f; }
.dg-b { font-size: 28rpx; font-weight: 700; color: #a73e2c; }
.dg-x { margin: 0 12rpx; color: #b8893a; font-size: 26rpx; }
.dg-tx {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #5d5346;
}

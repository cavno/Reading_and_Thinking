<view class="wrap">

  <!-- 标签切换 -->
  <view class="tabs">
    <view class="tab {{tab === 'concepts' ? 'tab-on' : ''}}" bindtap="switchTab" data-tab="concepts">
      <text>概念谱系</text>
    </view>
    <view class="tab {{tab === 'dual' ? 'tab-on' : ''}}" bindtap="switchTab" data-tab="dual">
      <text>张力总表</text>
    </view>
  </view>

  <!-- ===== 概念谱系 ===== -->
  <block wx:if="{{tab === 'concepts'}}">
    <text class="a-intro">六个概念,六条长河:看同一个词如何从神话流入哲学,再流入神学——直至今天。</text>

    <view wx:for="{{concepts}}" wx:key="id" wx:for-item="cv" class="cv-card">
      <view class="cv-head bd-{{cv.accent}}">
        <text class="cv-name">{{cv.name}}</text>
        <text class="cv-cn">{{cv.cn}}</text>
      </view>
      <text class="cv-line">{{cv.line}}</text>
      <view class="cv-stages">
        <view wx:for="{{cv.stages}}" wx:key="k" wx:for-item="st" class="cv-stage">
          <view class="cv-rail">
            <view class="cv-dot dt-{{cv.accent}}"></view>
            <view wx:if="{{index < cv.stages.length - 1}}" class="cv-rail-line"></view>
          </view>
          <view class="cv-body">
            <view class="cv-meta">
              <text class="cv-era">{{st.era}}</text>
              <text class="cv-who">{{st.who}}</text>
            </view>
            <text class="cv-tx">{{st.tx}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- ===== 张力总表 ===== -->
  <block wx:if="{{tab === 'dual'}}">
    <text class="a-intro">张力是思想的发动机:每个时代都用一对核心对立组织其精神世界。</text>

    <view wx:for="{{dualities}}" wx:key="id" wx:for-item="dg" class="dg-block">
      <view class="dg-head">
        <view class="dg-bar bg-{{dg.accent}}"></view>
        <text class="dg-title">{{dg.title}}</text>
      </view>
      <text class="dg-note">{{dg.note}}</text>
      <view wx:for="{{dg.pairs}}" wx:key="a" wx:for-item="p" class="dg-pair">
        <view class="dg-vs">
          <text class="dg-a">{{p.a}}</text>
          <text class="dg-x">/</text>
          <text class="dg-b">{{p.b}}</text>
        </view>
        <text class="dg-tx">{{p.tx}}</text>
      </view>
    </view>
  </block>

  <view class="foot">
    <text class="foot-tx">谱系与张力 · 跨四讲综合</text>
  </view>

</view>

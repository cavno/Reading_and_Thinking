page{ background:#f3ebda; color:#1c1916; font-family:Georgia, "Songti SC", serif; }
.app{ display:flex; flex-direction:column; height:100vh; box-sizing:border-box; }

/* ===== header ===== */
.header{ flex:none; background:#f6efe0; border-bottom:1rpx solid rgba(28,25,22,.14); padding:14rpx 20rpx 8rpx; }
.hbar{ display:flex; align-items:flex-start; justify-content:space-between; }
.titlewrap{ flex:1; min-width:0; }
.h1{ font-size:34rpx; font-weight:700; color:#1c1916; display:block; }
.sub{ font-size:20rpx; color:#6e6253; display:block; margin-top:2rpx; }
.acts{ display:flex; flex-direction:column; gap:8rpx; margin-left:12rpx; }
.btn{ font-size:23rpx; color:#3a342c; background:#faf4e6; border:1rpx solid rgba(28,25,22,.26); border-radius:30rpx; padding:7rpx 18rpx; text-align:center; white-space:nowrap; }
.btn.on{ background:#1c1916; color:#faf4e6; border-color:#1c1916; }

.board{ display:flex; flex-wrap:wrap; gap:10rpx; margin-top:12rpx; }
.law{ flex:1 1 46%; min-width:300rpx; box-sizing:border-box; border:1rpx solid rgba(28,25,22,.26); border-top:5rpx solid #999; border-radius:12rpx; background:#faf4e6; padding:9rpx 12rpx; }
.law-h{ display:flex; align-items:baseline; justify-content:space-between; margin-bottom:7rpx; }
.law-n{ font-size:25rpx; font-weight:700; }
.law-f{ font-size:19rpx; color:#6e6253; font-family:"Courier New",monospace; }
.seg{ display:flex; border:1rpx solid rgba(28,25,22,.26); border-radius:10rpx; overflow:hidden; }
.segbtn{ flex:1; text-align:center; font-size:23rpx; color:#3a342c; padding:8rpx 0; border-right:1rpx solid rgba(28,25,22,.14); }
.segbtn:last-child{ border-right:none; }
.segbtn.neu.active{ background:#6e6253; color:#fff; }
.segbtn.off.active{ background:#a73e2c; color:#fff; }

.legend{ white-space:nowrap; margin-top:10rpx; }
.legend .lg{ display:inline-flex; align-items:center; gap:6rpx; margin-right:18rpx; font-size:20rpx; color:#6e6253; }
.legend .pip{ width:18rpx; height:18rpx; border-radius:50%; }

/* ===== map ===== */
.mapwrap{ flex:1; min-height:0; }
.mapinner{ position:relative; width:100%; padding-bottom:90rpx; box-sizing:border-box; }
.bandbg{ position:absolute; left:8rpx; right:8rpx; background:rgba(29,78,95,.035); border-radius:14rpx; }
.bandlab{ position:absolute; left:18rpx; font-size:20rpx; letter-spacing:2rpx; color:#6e6253; text-transform:uppercase; }

.node{ position:absolute; box-sizing:border-box; background:#faf4e6; border:1rpx solid rgba(28,25,22,.26); border-radius:14rpx; padding:8rpx 12rpx; overflow:hidden; transition:opacity .2s; }
.node.dim{ opacity:.12; }
.node.hl{ border-width:3rpx; }
.node.sel{ border-width:4rpx; border-color:#a73e2c; }
.node.lin{ border-width:3rpx; border-color:#b8893a; }
.nrow{ display:flex; align-items:baseline; justify-content:space-between; }
.n-name{ font-size:26rpx; font-weight:700; color:#1c1916; }
.n-tag{ font-size:17rpx; font-weight:700; margin-left:6rpx; white-space:nowrap; }
.n-rep{ font-size:19rpx; color:#6e6253; display:block; margin-top:1rpx; }
.pips{ display:flex; align-items:center; margin-top:9rpx; }
.pips .pip{ width:18rpx; height:18rpx; border-radius:50%; margin-right:13rpx; }
.pipcap{ font-size:16rpx; color:#6e6253; margin-left:2rpx; }

/* ===== bottom sheet ===== */
.sheet{ position:fixed; left:0; right:0; bottom:0; background:#faf4e6; border-top:1rpx solid rgba(28,25,22,.2);
  box-shadow:0 -6rpx 24rpx rgba(28,25,22,.14); border-radius:22rpx 22rpx 0 0; z-index:50;
  height:64vh; transition:transform .3s ease; }
.sheet.closed{ transform:translateY(calc(64vh - 96rpx)); }
.sheet.open{ transform:translateY(0); }
.handle{ height:48rpx; display:flex; align-items:center; justify-content:center; }
.handle .bar{ width:80rpx; height:8rpx; border-radius:4rpx; background:rgba(28,25,22,.26); }
.sheetbody{ height:calc(64vh - 48rpx); padding:6rpx 26rpx 60rpx; box-sizing:border-box; }

.quad{ border:1rpx solid rgba(28,25,22,.26); border-radius:14rpx; background:#f3ebda; padding:14rpx 16rpx; margin-bottom:18rpx; }
.quad-t{ font-size:20rpx; letter-spacing:3rpx; color:#a73e2c; text-transform:uppercase; }
.quad-sub{ font-size:19rpx; color:#6e6253; margin:2rpx 0 11rpx; }
.quad-grid{ display:flex; flex-wrap:wrap; gap:10rpx; }
.qc{ flex:1 1 46%; box-sizing:border-box; border:1rpx solid rgba(28,25,22,.14); border-radius:10rpx; background:#faf4e6; padding:11rpx 12rpx; }
.qc-b{ font-size:24rpx; font-weight:700; color:#1c1916; display:block; }
.qc-s{ font-size:18rpx; color:#6e6253; }
.qc.active{ background:#1c1916; border-color:#1c1916; }
.qc.active .qc-b{ color:#faf4e6; } .qc.active .qc-s{ color:#d4b76a; }

.eyebrow{ font-size:20rpx; letter-spacing:3rpx; color:#a73e2c; text-transform:uppercase; margin-bottom:8rpx; }
.p-name{ font-size:46rpx; font-weight:700; line-height:1.15; }
.p-name.sm{ font-size:36rpx; }
.p-rep{ font-size:23rpx; color:#6e6253; margin:4rpx 0; }
.p-era{ display:inline-block; font-size:19rpx; background:#1d4e5f; color:#fff; border-radius:18rpx; padding:3rpx 14rpx; margin-bottom:14rpx; }
.stances{ margin:6rpx 0 14rpx; }
.st{ display:flex; align-items:center; padding:7rpx 0; }
.st .sn{ width:120rpx; font-size:24rpx; color:#3a342c; }
.st .pip{ width:22rpx; height:22rpx; border-radius:50%; margin:0 14rpx 0 4rpx; }
.st .sv{ font-size:24rpx; font-weight:700; }
.st .sf{ margin-left:auto; font-size:18rpx; color:#6e6253; font-family:"Courier New",monospace; }
.p-move{ font-size:26rpx; font-weight:600; color:#1c1916; border-left:6rpx solid #b8893a; padding:4rpx 0 4rpx 16rpx; margin-bottom:12rpx; }
.p-label{ font-size:20rpx; letter-spacing:3rpx; color:#a73e2c; text-transform:uppercase; margin:14rpx 0 7rpx; }
.note{ font-size:25rpx; line-height:1.7; color:#3a342c; }
.note.sm{ font-size:23rpx; color:#6e6253; }
.em{ color:#a73e2c; }

.btn-cfg{ display:inline-block; margin:16rpx 0 6rpx; font-size:23rpx; color:#a73e2c; border:1rpx solid #d9a89c; border-radius:30rpx; padding:8rpx 18rpx; }

.chips-h{ font-size:19rpx; letter-spacing:2rpx; color:#6e6253; text-transform:uppercase; margin:14rpx 0 8rpx; }
.chips{ display:flex; flex-wrap:wrap; }
.chip{ font-size:23rpx; color:#3a342c; background:#f3ebda; border:1rpx solid rgba(28,25,22,.26); border-radius:24rpx; padding:6rpx 16rpx; margin:0 12rpx 12rpx 0; }
.chip.anti{ border-style:dashed; }

.filt-active{ margin-bottom:8rpx; }
.fa{ font-size:28rpx; font-weight:600; margin-right:14rpx; }
.fav{ font-weight:700; margin-left:4rpx; }

.pipline,.pipkeys{ display:flex; flex-wrap:wrap; margin:10rpx 0; }
.pk{ display:inline-flex; align-items:center; gap:6rpx; margin:0 16rpx 8rpx 0; font-size:22rpx; }
.pk .pip{ width:22rpx; height:22rpx; border-radius:50%; }

.play-ctrl{ display:flex; align-items:center; gap:14rpx; margin-bottom:10rpx; }
.pbtn{ width:60rpx; height:60rpx; border-radius:50%; border:1rpx solid rgba(28,25,22,.26); background:#f3ebda; display:flex; align-items:center; justify-content:center; font-size:30rpx; color:#1c1916; }
.pbtn.main{ background:#1c1916; color:#faf4e6; border-color:#1c1916; }
.play-idx{ font-size:23rpx; color:#6e6253; margin-left:6rpx; }
.play-items{ margin-top:10rpx; }
.pi{ padding:10rpx 0; border-bottom:1rpx solid rgba(28,25,22,.1); }
.pi-n{ font-size:26rpx; font-weight:700; color:#1c1916; }
.pi-m{ font-size:23rpx; color:#3a342c; display:block; margin-top:2rpx; }
